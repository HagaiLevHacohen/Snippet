// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  revoked   Boolean  @default(false)
  replacedByToken String?

  @@index([userId])
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  email          String   @unique
  googleId       String?  @unique
  authProvider   String   @default("local")
  name           String
  refreshTokens RefreshToken[]
  status         String?
  passwordHashed String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  avatarUrl      String?

  following UserFollow[] @relation("Following")
  followers UserFollow[] @relation("Followers")

  outgoingRequests FollowRequest[] @relation("OutgoingRequests")
  incomingRequests FollowRequest[] @relation("IncomingRequests")

  posts    Post[]
  likes    Like[]
  comments Comment[]

  conversationsAsUser1 Conversation[] @relation("User1Conversations")
  conversationsAsUser2 Conversation[] @relation("User2Conversations")

  sentMessages Message[]
}

model UserFollow {
  followerId  Int
  followingId Int

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade) // who started it
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade) // who receives it

  @@id([followerId, followingId])
}

model Like {
  userId Int
  postId Int

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId]) // prevents duplicate likes
}

model FollowRequest {
  outgoingRequestId Int
  incomingRequestId Int

  outgoingRequest User @relation("OutgoingRequests", fields: [outgoingRequestId], references: [id], onDelete: Cascade)
  incomingRequest User @relation("IncomingRequests", fields: [incomingRequestId], references: [id], onDelete: Cascade)

  status FollowRequestStatus @default(PENDING)

  @@id([outgoingRequestId, incomingRequestId])
}

enum FollowRequestStatus {
  PENDING
  REJECTED
}

model Post {
  id        Int      @id @default(autoincrement())
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  imageUrl  String?

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  likes    Like[]
  comments Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int
}

model Conversation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // participants
  user1Id Int
  user2Id Int

  lastMessageId Int?
  lastMessage   Message? @relation("LastMessage", fields: [lastMessageId], references: [id])

  user1 User @relation("User1Conversations", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("User2Conversations", fields: [user2Id], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([user1Id, user2Id]) // ensures only one conversation per pair
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  senderId       Int
  conversationId Int

  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // read tracking
  isRead Boolean @default(false)

  conversationLastMessage Conversation[] @relation("LastMessage")

  imageUrl String?

  @@index([conversationId, createdAt])
}
